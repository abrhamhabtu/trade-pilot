{
  "name": "trade-pilot",
  "version": "1.0.0",
  "description": "Trading analytics dashboard for prop firm traders",
  "author": "Abrham Habtu",
  "license": "AGPL-3.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/abrhamhabtu/trade-pilot.git"
  },
  "scripts": {
    "setup": "npm run install:web",
    "install:web": "npm --prefix apps/web install",
    "dev": "npm --prefix apps/web run dev -- -p 3001",
    "dev:3000": "npm --prefix apps/web run dev -- -p 3000",
    "build": "npm --prefix apps/web run build",
    "start": "npm --prefix apps/web run start -- -p 3001",
    "lint": "npm --prefix apps/web run lint"
  }
}
